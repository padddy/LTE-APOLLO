static inline void DBG_prefix() {
  if (DBG_lineStart) {
    unsigned long ms  = millis();
    unsigned long sec = ms / 1000;
    unsigned long rem = ms % 1000;
    char ts[20];
    sprintf(ts, "[%lu.%03lu] ", sec, rem);  // z.B. [123.456]
    Serial.print(ts);
    DBG_lineStart = false;
  }
}

