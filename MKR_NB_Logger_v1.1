void setup() {
  pinMode(LED_PIN, OUTPUT);
  pinMode(PIN_BUTTON, INPUT_PULLUP);
  digitalWrite(LED_PIN, HIGH);
  rtc.begin();

#ifdef DEBUG_SERIAL
  Serial.begin(DEBUG_BAUD);
  unsigned long __t0 = millis();
  while (!Serial && millis()-__t0 < 1500) {}
  DEBUG_PRINTLN("\nStarting " SENSOR_ID " firmware " SOFTWARE_VERSION);
#endif

  shutdownLTE();      // sauberer Kaltstart
  // Einmaliges LTE-Fenster für Boot: NTP -> danach Sensoren/SD -> Statfile -> Upload
  // Einmaliges LTE-Fenster für Boot
if (initLTE()) {
  bool pathOK = datapathOK();

  // Sensoren jetzt initialisieren (Zeit egal; wir loggen immer)
  if (!checkBME()) { blinkError(3); DEBUG_PRINTLN("BME init failed"); }
  if (sht31.begin(0x44)) { hasSHT85 = true; sht31.heater(false); DEBUG_PRINTLN("SHT85 ready (0x44)"); }
  else { DEBUG_PRINTLN("SHT85 not found"); }

  // SD mounten (immer, damit Logger läuft)
  sdMounted = initSD();

  if (pathOK) {
    // NUR wenn Datapath OK: NTP + Status-Upload
    if (syncTime()) DEBUG_PRINTLN("Boot time sync OK");
    else            DEBUG_PRINTLN("Boot time sync FAILED");

    if (sdMounted) {
      String statName = String(SENSOR_ID) + "start.txt";
      File stat = SD.open(statName, FILE_WRITE);
      if (stat) {
        appendStatusData(stat);
        stat.close();
        if (ftpUpload(statName, FTP_STAT_DIR)) {
          DEBUG_PRINTLN("Boot status upload OK");
          // Optional: SD.remove(statName);
        } else {
          DEBUG_PRINTLN("Boot status upload FAILED");
        }
      } else {
        DEBUG_PRINTLN("Boot status file open failed");
      }
    } else {
      DEBUG_PRINTLN("SD not mounted at boot");
    }
  } else {
    DEBUG_PRINTLN("Datapath NOT OK → skipping NTP and FTP at boot");
  }

  shutdownLTE();  // EINMAL aus
} else {
  DEBUG_PRINTLN("LTE init FAILED at boot – skipping time sync & boot upload");
  if (!checkBME()) { blinkError(3); }
  if (sht31.begin(0x44)) { hasSHT85 = true; sht31.heater(false); }
  sdMounted = initSD();
}


  // Tagesdatei für heute vorbereiten (Header sicherstellen)
  currentDayStamp = timeStamp();
  currentFile = String(SENSOR_ID) + currentDayStamp + ".csv";
  ensureDataFileHasHeader();

  startDay   = millis();
  lastMinute = millis();
 
  DEBUG_PRINTLN("Initialization complete");
  digitalWrite(LED_PIN, LOW);
}



//------------------------------------------------LOOP------------------------------------------------


void loop() {
  if (!runMainLoop) {    // nur LED heartbeat
    digitalWrite(LED_PIN, !digitalRead(LED_PIN));
    delay(250);
    return;
  }

//  if (!SD.begin(PIN_SD_CS)) {
//    digitalWrite(LED_PIN, LOW);
//    DEBUG_PRINTLN("SD card not present");
//    delay(1000);
//    return;
//  }

  if (!sdMounted) {
   sdMounted = SD.begin(PIN_SD_CS);
   if (!sdMounted) { DEBUG_PRINTLN("SD init failed"); delay(1000); return; }
  }


   if (digitalRead(PIN_BUTTON) == LOW) {
    dataFile.close();
    SD.end();
    sdMounted = false;
    DEBUG_PRINTLN("SD card unmounted");
    while (digitalRead(PIN_BUTTON) == LOW) { delay(50); }
    DEBUG_PRINTLN("Button released");
    runMainLoop = false; //💡 Mainloop anhalten, ab jetzt nur blinken!
    return;
  }

  // Tageswechsel erkennen -> neue Datei + Header
static int lastYmd = -1;
int nowYmd = ymdInt(year(), month(), day());
if (lastYmd != nowYmd) {
  lastYmd = nowYmd;
  currentDayStamp = timeStamp();
  currentFile = makeDayFileName(year(), month(), day());
  ensureDataFileHasHeader();
  DEBUG_PRINT("New day file: "); DEBUG_PRINTLN(currentFile);
}


 if (millis() - lastMinute >= 60000UL) {
  File df = SD.open(currentFile, FILE_WRITE);
  if (df) { appendData(df); df.close(); DEBUG_PRINTLN("Data logged"); }
  else    { DEBUG_PRINTLN("Open data file failed"); }
  lastMinute += 60000UL;
}
// 02:00: Timesync + Upload der VORTAGES-Datei
if (hour()==2 && minute()==0) {
  int todayY = year(), todayM = month(), todayD = day();
  int key = ymdInt(todayY, todayM, todayD);
  if (lastDailySyncYmd != key) {            // Flankenerkennung: nur 1x pro Tag
    lastDailySyncYmd = key;

    // gestern berechnen + Dateiname bilden
    int y=todayY, m=todayM, d=todayD;
    ymdYesterday(y,m,d);
    String yestFile = makeDayFileName(y,m,d);
    DEBUG_PRINT("Daily job 02:00 → yesterday: "); DEBUG_PRINTLN(yestFile);

    shutdownLTE();      // sauberer Kaltstart
    // LTE für gesamten Job EINMAL an
    if (initLTE()) {
      bool pathOK = datapathOK();
      if (pathOK) {
      if (syncTime()) DEBUG_PRINTLN("Daily time sync OK");
      else            DEBUG_PRINTLN("Daily time sync FAILED");

      File yf = SD.open(yestFile, FILE_READ);
      if (yf) {
        yf.close();
        if (ftpUpload(yestFile, FTP_DATA_DIR)) {
          DEBUG_PRINT("Daily upload OK: "); DEBUG_PRINTLN(yestFile);
        } else {
          DEBUG_PRINT("Daily upload FAILED: "); DEBUG_PRINTLN(yestFile);
        }
      } else {
        DEBUG_PRINT("No yesterday file (skip): "); DEBUG_PRINTLN(yestFile);
      }
    } else {
      DEBUG_PRINTLN("Datapath NOT OK → skipping NTP/FTP in daily job");
    }
    shutdownLTE();
  } else {
  DEBUG_PRINTLN("LTE init FAILED for daily job");
  }
  }
}

  digitalWrite(LED_PIN, HIGH);
  delay(10);
  digitalWrite(LED_PIN, LOW);
  // DEBUG_PRINTLN("Measurement done");
  delay(1000);
}
