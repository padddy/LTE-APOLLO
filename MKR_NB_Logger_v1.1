// Date-Helfer
bool isLeap(int y){ return (y%4==0 && (y%100!=0 || y%400==0)); }
int daysInMonth(int y,int m){
  static const int d[12]={31,28,31,30,31,30,31,31,30,31,30,31};
  if(m==2) return d[m-1]+(isLeap(y)?1:0); else return d[m-1];
}
void ymdYesterday(int &y,int &m,int &d){
  if(--d==0){ if(--m==0){ m=12; y--; } d = daysInMonth(y,m); }
}
int ymdInt(int y,int m,int d){ return y*10000 + m*100 + d; }

String makeDayFileName(int y,int m,int d){
  char stamp[7]; // YYMMDD
  sprintf(stamp,"%02d%02d%02d", y%100, m, d);
  return String(SENSOR_ID) + String(stamp) + ".csv";
}

