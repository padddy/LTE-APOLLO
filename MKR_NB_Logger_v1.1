void blinkError(int hz) {
  int delayMs = 500 / hz;
  for (int i = 0; i < hz*2; ++i) {
    digitalWrite(LED_PIN, !digitalRead(LED_PIN));
    delay(delayMs);
  }
  digitalWrite(LED_PIN, LOW);
}

float readNTC() {
  int raw = analogRead(PIN_NTC);
  float resistance = (10000.0 * raw) / (1023.0 - raw); // <-- Diese Zeile geändert!
  float steinhart;
  steinhart = resistance / 10000.0;
  steinhart = log(steinhart);
  steinhart /= NTC_BETA;
  steinhart += 1.0 / (25.0 + 273.15);
  steinhart = 1.0 / steinhart;
  steinhart -= 273.15;
  steinhart += NTC_OFFSET;
  return steinhart;
}


float readBattery() {
  int raw = analogRead(PIN_BAT);
  return raw * (2.0 * 3.3 / 1023.0); // 100k/100k divider
}


void readSHT85(float &t, float &h) {
  t = NAN; h = NAN;
  if (!hasSHT85) return;

  t = sht31.readTemperature();
  h = sht31.readHumidity();

  if (isnan(t) || isnan(h)) {
    delay(20);
    t = sht31.readTemperature();
    h = sht31.readHumidity();
  }

  // einfache Plausi (optional)
  if (!(t > -45.0f && t < 130.0f)) t = NAN;
  if (!(h >= 0.0f && h <= 100.0f)) h = NAN;
}


bool checkBME() {
  DEBUG_PRINTLN("Checking BME280...");
  Wire.begin();
  Wire.setClock(100000); // konservativ
  // Falls Adresse variabel ist: erst 0x76, dann 0x77 probieren
  if (!bme.begin(BME_ADDRESS, &Wire)) {
    // optional: zweite Adresse probieren
    #if defined(BME_ALT_ADDRESS)
    if (!bme.begin(BME_ALT_ADDRESS, &Wire)) {
      DEBUG_PRINTLN("BME280 not found");
      return false;
    }
    #else
    DEBUG_PRINTLN("BME280 not found");
    return false;
    #endif
  }

  // ein paar Messversuche
  for (int i = 0; i < 3; ++i) { delay(20); bme.readTemperature(); }

  float t = bme.readTemperature();
  float p = bme.readPressure() / 100.0;
  float h = bme.readHumidity();

  if (isnan(t) || isnan(p) || isnan(h)) {
    DEBUG_PRINTLN("BME280 returns NaN");
    return false;
  }
  if (!(t > TEMP_MIN && t < TEMP_MAX &&
        p > PRESS_MIN && p < PRESS_MAX &&
        h > HUM_MIN && h < HUM_MAX)) {
    DEBUG_PRINTLN("BME280 sanity check failed");
    return false;
  }

  DEBUG_PRINTLN("BME280 ready");   // <- Erfolgsmeldung HIER
  return true;
}


bool initLTE() {
  DEBUG_PRINTLN("Initializing LTE...");

  // Modemstart (3 Versuche)
  for (int attempt = 1; attempt <= 3; ++attempt) {
    DEBUG_PRINT("NB begin attempt "); DEBUG_PRINTLN(attempt);
    if (nbAccess.begin(SIM_PIN) == NB_READY) {
      DEBUG_PRINTLN("NB ready");
      break;
    }
    DEBUG_PRINTLN("NB begin failed -> shutdown + retry");
    nbAccess.shutdown();
    delay(1500);
    if (attempt == 3) return false;
  }

  // GPRS attach (APN aus config.h; falls nicht nötig, #undef NB_APN)
  DEBUG_PRINTLN("Attaching GPRS...");

#ifdef NB_APN
  if (gprs.attachGPRS(NB_APN, NB_USER, NB_PASS) != GPRS_READY) {
    DEBUG_PRINTLN("GPRS attach failed");
    return false;
  }
#else
  if (gprs.attachGPRS() != GPRS_READY) {
    DEBUG_PRINTLN("GPRS attach failed");
    return false;
  }
#endif

// ✅ Hier sicherstellen, dass wirklich eine IP da ist
if (!waitForIP(10000)) {
  DEBUG_PRINTLN("GPRS ready but no IP → datapath likely broken");
  // optional: einmal sauber neu versuchen
  gprs.detachGPRS(); delay(1500);
#ifdef NB_APN
  if (gprs.attachGPRS(NB_APN, NB_USER, NB_PASS) != GPRS_READY || !waitForIP(8000)) return false;
#else
  if (gprs.attachGPRS() != GPRS_READY || !waitForIP(8000)) return false;
#endif
}

DEBUG_PRINTLN("LTE ready");
lteActive = true;
return true;
}


void shutdownLTE() {
  // Wenn Modem nie gestartet wurde: nichts „hartes“ tun
  if (!lteActive) {
    // UDP-Socket in jedem Fall freigeben, damit syncTime() neu bindet
    udp.stop();
    udpReady = false;
    DEBUG_PRINTLN("shutdownLTE: modem not active; skipping power-down");
    return;
  }

  // PDP-Kontext räumen (best effort)
  gprs.detachGPRS();
  delay(2000);

  // Modem sauber runterfahren
  nbAccess.shutdown();
  delay(3000);

  lteActive = false;

  // UDP invalidieren (nächstes syncTime() macht udp.begin() neu)
  udp.stop();
  udpReady = false;

  DEBUG_PRINTLN("shutdownLTE: done");
}


// Synchronisiert die RTC-Zeit mit einem NTP-Server über UDP.
// Berechnet außerdem die Zeitabweichung und speichert die aktuellen/letzten Sync-Werte für spätere Vergleiche.
bool syncTime() {
  DEBUG_PRINTLN("Syncing time via NTP...");

  const unsigned long NTP_TIMEOUT_MS = 15000UL; // LTE-M kann träge sein

  // Sauber starten
  udp.stop();
  delay(300);

  // Einmal binden (Port-Hopping, falls ein Port blockiert ist)
  uint16_t base = 40000u + (millis() & 0x03FFu);
  bool begun = false;
  for (int i = 0; i < 4 && !begun; ++i) {
    uint16_t lp = base + i * 7u;
    begun = udp.begin(lp);
    if (!begun) { DEBUG_PRINTLN("udp.begin failed"); delay(200); }
  }
  if (!begun) { DEBUG_PRINTLN("No NTP socket"); return false; }

  for (int attempt = 1; attempt <= 2; ++attempt) {
    DEBUG_PRINT("NTP attempt "); DEBUG_PRINTLN(attempt);

    // Sendezeit (lokal, ms)
    unsigned long t_send_ms = millis();
    sendNTPpacket(ntpServer);

    // Auf Antwort warten
    unsigned long wait_start = millis();
    while (millis() - wait_start < NTP_TIMEOUT_MS) {
      int sz = udp.parsePacket();
      if (sz >= NTP_PACKET_SIZE) {
        unsigned long t_recv_ms = millis(); // Empfangszeit (lokal, ms)
        udp.read(packetBuffer, NTP_PACKET_SIZE);

        // Server-Transmit-Time: Sekunden seit 1900
        uint32_t hw = word(packetBuffer[40], packetBuffer[41]);
        uint32_t lw = word(packetBuffer[42], packetBuffer[43]);
        const uint32_t SEVENTY_YEARS = 2208988800UL;
        uint32_t t3_epoch_s = ((hw << 16) | lw) - SEVENTY_YEARS; // Unix seconds

        // RTT/2 (ms)
        uint32_t rtt_ms = t_recv_ms - t_send_ms;
        uint32_t half_rtt_ms = rtt_ms / 2u;

        // **Alles in 64-bit Millisekunden rechnen**
        uint64_t t4_epoch_ms = (uint64_t)t3_epoch_s * 1000ULL + (uint64_t)half_rtt_ms; // Serverzeit zum Empfangsmoment
        uint64_t rtc_now_ms  = (uint64_t)rtc.getEpoch() * 1000ULL;

        int64_t diff_ms_64 = (int64_t)t4_epoch_ms - (int64_t)rtc_now_ms;

        // globale timeDiffMs (32-bit) sicher setzen (Saturation auf 32-bit Range)
        if (diff_ms_64 >  2147483647LL) diff_ms_64 =  2147483647LL;
        if (diff_ms_64 < -2147483648LL) diff_ms_64 = -2147483648LL;
        timeDiffMs = (long)diff_ms_64;

        // RTC nur stellen, wenn Abweichung > 1000 ms
        int64_t absdiff = (diff_ms_64 >= 0 ? diff_ms_64 : -diff_ms_64);
        if (absdiff > 1000LL) {
          rtc.setEpoch((uint32_t)(t4_epoch_ms / 1000ULL));
        }

        DEBUG_PRINT("NTP RTT [ms]: "); DEBUG_PRINTLN(rtt_ms);
        DEBUG_PRINT("RTC diff [ms] (recv-moment): "); DEBUG_PRINTLN(timeDiffMs);
        DEBUG_PRINTLN("Time synced via NTP");

        udp.stop();
        return true;
      }
      delay(50);
    }

    DEBUG_PRINTLN("NTP timeout on this attempt");
  }

  udp.stop();
  DEBUG_PRINTLN("No NTP response");
  return false;
}



bool initSD() {
  DEBUG_PRINTLN("Initializing SD...");
  SPI.begin();                     // sicherstellen
  pinMode(PIN_SD_CS, OUTPUT);      // CS definieren
  digitalWrite(PIN_SD_CS, HIGH);   // CS inaktiv

  for (int i=0; i<3; ++i) {
    if (SD.begin(PIN_SD_CS)) {
      DEBUG_PRINTLN("SD card ready");    // <- nur hier loggen
      return true;
    }
    DEBUG_PRINTLN("SD init failed, retry...");
    delay(200);
  }
  DEBUG_PRINTLN("SD init failed");
  return false;
}

