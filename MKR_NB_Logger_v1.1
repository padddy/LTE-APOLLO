}

void ensureDataFileHasHeader() {
  File f = SD.open(currentFile, FILE_WRITE);
  if (!f) return;
  if (f.size() == 0) {
    f.println(DATA_HEADER);
    f.flush();
  }
  f.close();
}

void appendData(File &f) {
  // Header, falls Datei neu/leer
  if (f.size() == 0) {
    f.println(DATA_HEADER);
    f.flush();
  }

  float sht_t, sht_h;
  readSHT85(sht_t, sht_h);

  char buf[160];
  // YYMMDD;HH:MM:SS;NTC_T;BME_T;BME_P;BME_H;SHT_T;SHT_H;BattV
  snprintf(buf, sizeof(buf),
           "%02d%02d%02d;%02d:%02d:%02d;%.2f;%.2f;%.2f;%.2f;%s;%s;%.2f",
           year() % 100, month(), day(), hour(), minute(), second(),
           readNTC(), bme.readTemperature(), bme.readPressure() / 100.0,
           bme.readHumidity(),
           (isnan(sht_t) ? "nan" : String(sht_t, 2).c_str()),
           (isnan(sht_h) ? "nan" : String(sht_h, 2).c_str()),
           readBattery());

  f.println(buf);
  DEBUG_PRINTLN(buf);
}

void appendStatusData(File &f) {
  float sht_t, sht_h;
  readSHT85(sht_t, sht_h);

  char buf[160];
  // Format: YYMMDD;HH:MM:SS;NTC_T;BME_T;BME_P;BME_H;SHT_T;SHT_H;BattV;TimeDiff
  snprintf(buf, sizeof(buf),
           "%02d%02d%02d;%02d:%02d:%02d;%.2f;%.2f;%.2f;%.2f;%s;%s;%.2f;%ld",
           year() % 100, month(), day(), hour(), minute(), second(),
           readNTC(), bme.readTemperature(), bme.readPressure() / 100.0,
           bme.readHumidity(),
           (isnan(sht_t) ? "nan" : String(sht_t, 2).c_str()),
           (isnan(sht_h) ? "nan" : String(sht_h, 2).c_str()),
           readBattery(),
           timeDiffMs);

  f.println(buf);
  DEBUG_PRINTLN(buf);
}


bool ftpUpload(const String &localName, const char *remoteDir) {
  DEBUG_PRINTLN("===== FTP UPLOAD START (PASV only, IP match) =====");

  File f = SD.open(localName);
  if (!f) { DEBUG_PRINTLN("FTP open failed"); return false; }
  const size_t fileSize = f.size();

  NBClient ctrl, data;
  IPAddress dataIP;
  int dataPort = 0;

  // --- Helpers --------------------------------------------------------------

  // Liest bis zum nächsten CRLF und liefert exakt diese Zeile (ohne CRLF)
  auto readLine = [&](String &line, unsigned long timeout)->bool {
    line = "";
    unsigned long t0 = millis();
    while (millis() - t0 < timeout) {
      while (ctrl.available()) {
        char c = ctrl.read();
        if (c == '\r') continue;
        if (c == '\n') {
          return line.length() > 0;
        }
        line += c;
        if (line.length() > 512) line.remove(0, line.length() - 256);
      }
      delay(10);
    }
    return line.length() > 0;
  };

  auto expectCode = [&](const char *code, unsigned long timeout)->bool {
    String line;
    if (!readLine(line, timeout)) return false;
    DEBUG_PRINT("<< "); DEBUG_PRINTLN(line);
    return line.startsWith(code); // akzeptiert z.B. "220" und "220-..."
  };

  // Daten-Socket verbinden (immer zu dataIP:dataPort, nie zum Hostnamen!)
  auto connectDataSocket = [&](const IPAddress& ip, uint16_t port)->bool {
    DEBUG_PRINT("Data target "); DEBUG_PRINT(ip); DEBUG_PRINT(":"); DEBUG_PRINTLN(port);
    unsigned long start = millis();
    while (millis() - start < 10000) {
      if (data.connect(ip, port)) return true;
      delay(100);
    }
    DEBUG_PRINTLN("Data connect failed");
    return false;
  };

  // --- Control connect ------------------------------------------------------

  DEBUG_PRINT("FTP ctrl connect "); DEBUG_PRINT(FTP_SERVER); DEBUG_PRINT(":"); DEBUG_PRINTLN(FTP_PORT);
  if (!ctrl.connect(FTP_SERVER, FTP_PORT)) { f.close(); return false; }

  if (!expectCode("220", 8000)) { ctrl.stop(); f.close(); return false; } // Banner

  ctrl.print("USER " FTP_USER "\r\n");
  // manche Server springen direkt zu 230 – 331 ist nice-to-have
  (void)expectCode("331", 8000);

  ctrl.print("PASS " FTP_PASS "\r\n");
  if (!expectCode("230", 8000)) { ctrl.stop(); f.close(); return false; }

  ctrl.print("TYPE I\r\n");
  if (!expectCode("200", 6000)) { ctrl.stop(); f.close(); return false; }

  // CWD (bei Bedarf MKD)
  ctrl.print("CWD "); ctrl.print(remoteDir); ctrl.print("\r\n");
  if (!expectCode("250", 6000)) {
    ctrl.print("MKD "); ctrl.print(remoteDir); ctrl.print("\r\n");
    { String dump; readLine(dump, 8000); } // kein Heap-Leak
    ctrl.print("CWD "); ctrl.print(remoteDir); ctrl.print("\r\n");
    if (!expectCode("250", 6000)) { ctrl.stop(); f.close(); return false; }
  }

  // --- Passive Aushandlung: PASV (227) erzwingen ---------------------------

  auto getPassivePortPASV = [&]()->bool {
    String line;
    ctrl.print("PASV\r\n");
    if (!readLine(line, 6000)) return false;
    DEBUG_PRINT("<< "); DEBUG_PRINTLN(line);
    if (!line.startsWith("227")) return false;

    // Format: 227 Entering Passive Mode (h1,h2,h3,h4,p1,p2).
    int p1 = line.indexOf('('), p2 = line.indexOf(')', p1);
    if (p1 < 0 || p2 < p1) return false;
    int a1,a2,a3,a4,ph,pl; a1=a2=a3=a4=ph=pl=0;
    // robust gegen Spaces: substring extrahieren
    String inside = line.substring(p1+1, p2);
    if (sscanf(inside.c_str(), "%d,%d,%d,%d,%d,%d", &a1,&a2,&a3,&a4,&ph,&pl) != 6) return false;
    dataIP = IPAddress(a1,a2,a3,a4);
    dataPort = (ph << 8) | pl;
    return (dataPort > 0);
  };

  if (!getPassivePortPASV()) {
    DEBUG_PRINTLN("PASV negotiation failed");
    ctrl.stop(); f.close(); return false;
  }

  DEBUG_PRINT("Passive data port: "); DEBUG_PRINTLN(dataPort);

  // --- Adaptiver STOR/Daten-Handshake --------------------------------------

  // Versuch A: STOR → (warte 150/125) → dann Daten verbinden
  bool have150 = false;
  {
    ctrl.print("STOR "); ctrl.print(localName); ctrl.print("\r\n");
    String lineA;
    unsigned long waitA = millis();
    while (millis() - waitA < 6000) {
      if (readLine(lineA, 1000)) {
        DEBUG_PRINT("<< "); DEBUG_PRINTLN(lineA);
        if (lineA.indexOf("150") != -1 || lineA.indexOf("125") != -1) { have150 = true; break; }
        // andere 1xx/2xx ignorieren bis Timeout
      }
    }
  }

  if (have150) {
    if (!connectDataSocket(dataIP, (uint16_t)dataPort)) { ctrl.stop(); f.close(); return false; }
    DEBUG_PRINTLN("Data socket connected (A)");
  } else {
    // Fallback B: erst Daten verbinden, dann STOR erneut senden und 150/125 abwarten
    DEBUG_PRINTLN("No 150 after STOR (A) → trying pre-connect (B)");
    if (!connectDataSocket(dataIP, (uint16_t)dataPort)) { ctrl.stop(); f.close(); return false; }
    DEBUG_PRINTLN("Data socket connected (B)");

    ctrl.print("STOR "); ctrl.print(localName); ctrl.print("\r\n");
    String lineB;
    bool have150b = false;
    unsigned long waitB = millis();
    while (millis() - waitB < 10000) {
      if (readLine(lineB, 1000)) {
        DEBUG_PRINT("<< "); DEBUG_PRINTLN(lineB);
        if (lineB.indexOf("150") != -1 || lineB.indexOf("125") != -1) { have150b = true; break; }
      }
    }
    if (!have150b) {
      DEBUG_PRINTLN("No 150/125 after STOR (B)");
      data.stop(); ctrl.stop(); f.close(); return false;
    }
  }

  // --- Transfer -------------------------------------------------------------

  DEBUG_PRINTLN("Transferring file...");
  unsigned long t0 = millis();
  unsigned long overallDeadline = millis() + 60000; // max 60 s für den ganzen Upload
  size_t totalBytes = 0;
  uint8_t buf[128]; // kleinere Chunks sind über LTE-M stabiler

  while (f.available() && millis() < overallDeadline) {
    int len = f.read(buf, sizeof(buf));
    if (len <= 0) break;

    size_t sent = 0;
    unsigned long deadline = millis() + 10000; // 10 s pro Chunk
    while (sent < (size_t)len && millis() < deadline && millis() < overallDeadline) {
      size_t w = data.write(buf + sent, len - sent);
      if (w > 0) { sent += w; totalBytes += w; }
      else { delay(5); }
    }
    if (sent < (size_t)len) { DEBUG_PRINTLN("Short write → abort"); break; }
  }

  data.stop();

  // Best-effort: finalen 226 einsammeln
  {
    String lineEnd;
    if (readLine(lineEnd, 5000)) { DEBUG_PRINT("<< "); DEBUG_PRINTLN(lineEnd); }
  }

  DEBUG_PRINT("Transfer time [ms]: "); DEBUG_PRINTLN(millis() - t0);
  DEBUG_PRINT("Transferred bytes: ");  DEBUG_PRINTLN(totalBytes);

  ctrl.print("QUIT\r\n");
  { String line; readLine(line, 1500); }

  ctrl.stop();
  f.close();

  DEBUG_PRINTLN("===== FTP UPLOAD END =====");
  return (totalBytes == fileSize);
}





